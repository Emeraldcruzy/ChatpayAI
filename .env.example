# ═══════════════════════════════════════════
# MantleGuard Environment Configuration
# ═══════════════════════════════════════════

# ─── Telegram Bot ──────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=random_secret_string

# ─── Mantle Network ───────────────────────
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz

# ─── Deployer / Agent Keys ─────────────────
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key
AGENT_PRIVATE_KEY=0x_your_agent_executor_private_key

# ─── Contract Addresses (fill after deploy) 
IDENTITY_REGISTRY=0x...
SPENDING_POLICY=0x...
MNT_GAS_RESERVE=0x...
MUSD_TOKEN=0x...
PAYMENT_SCHEDULER=0x...
SUBSCRIPTION_MANAGER=0x...
EXECUTION_ROUTER=0x...
TREASURY=0x...

# ─── Scheduler ─────────────────────────────
SCHEDULER_INTERVAL_MS=60000
SCHEDULER_BATCH_SIZE=10

# ─── Explorer ──────────────────────────────
MANTLE_EXPLORER_API_KEY=your_api_key

# ─── ZK Verifier ──────────────────────────
ZK_VERIFIER_URL=http://localhost:3001/verify
